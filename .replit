modules = ["python-3.12", "web", "nodejs-20"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Ball Frontend"

[[workflows.workflow]]
name = "Ball Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ball_frontend && npm run dev"

[[ports]]
localPort = 5173
externalPort = 80
